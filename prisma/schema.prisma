// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum UserRole {
  ADMIN
  USER
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum GroupRole {
  OWNER
  ADMIN
  MEMBER
}

enum ExpenseSplitType {
  EQUAL
  EXACT
  PERCENTAGE
  SHARES
}

enum SettlementStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum NotificationType {
  EXPENSE_CREATED
  EXPENSE_UPDATED
  SETTLEMENT_REQUESTED
  SETTLEMENT_COMPLETED
  GROUP_INVITE
  RECOMMENDATION_READY
  ITINERARY_READY
  SYSTEM
}

enum PollStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum ItineraryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
}

// ============================================================
// Core Models
// ============================================================

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  username        String       @unique
  role            UserRole     @default(USER)
  isActive        Boolean      @default(true)
  isEmailVerified Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  // Relations
  profile          UserProfile?
  settings         UserSettings?
  accounts         UserAccount[]
  refreshTokens    RefreshToken[]
  groupMemberships GroupMember[]
  expensesPaid     Expense[]       @relation("ExpensePayer")
  expenseSplits    ExpenseSplit[]
  settlementsFrom  Settlement[]    @relation("SettlementFrom")
  settlementsTo    Settlement[]    @relation("SettlementTo")
  notifications    Notification[]
  pollVotes        PollVote[]
  auditLogs        AuditLog[]

  @@map("users")
  @@index([email])
  @@index([username])
}

model UserProfile {
  id          String  @id @default(uuid())
  userId      String  @unique
  displayName String
  avatarUrl   String?
  phoneNumber String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserSettings {
  id                      String  @id @default(uuid())
  userId                  String  @unique
  defaultCurrency         String  @default("VND")
  notificationPreferences Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model UserAccount {
  id                String       @id @default(uuid())
  userId            String
  provider          AuthProvider
  providerAccountId String?
  passwordHash      String?
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("user_accounts")
  @@index([userId])
}

model RefreshToken {
  id          String   @id @default(uuid())
  token       String   @unique
  userId      String
  expiresAt   DateTime
  isRevoked   Boolean  @default(false)
  createdAt   DateTime @default(now())
  ipAddress   String?
  userAgent   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([token])
  @@index([userId])
}

// ============================================================
// Groups
// ============================================================

model Group {
  id          String    @id @default(uuid())
  name        String
  description String?
  avatarUrl   String?
  currency    String    @default("USD")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  members      GroupMember[]
  expenses     Expense[]
  settlements  Settlement[]
  polls        Poll[]
  itineraries  Itinerary[]
  notifications Notification[]

  @@map("groups")
}

model GroupMember {
  id        String    @id @default(uuid())
  groupId   String
  userId    String
  role      GroupRole @default(MEMBER)
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
  @@index([groupId])
  @@index([userId])
}

// ============================================================
// Expenses
// ============================================================

model Expense {
  id          String           @id @default(uuid())
  groupId     String
  payerId     String
  title       String
  description String?
  amount      Decimal          @db.Decimal(12, 2)
  currency    String           @default("USD")
  splitType   ExpenseSplitType @default(EQUAL)
  categoryId  String?
  receiptUrl  String?
  date        DateTime         @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  group    Group         @relation(fields: [groupId], references: [id])
  payer    User          @relation("ExpensePayer", fields: [payerId], references: [id])
  category Category?     @relation(fields: [categoryId], references: [id])
  splits   ExpenseSplit[]

  @@map("expenses")
  @@index([groupId])
  @@index([payerId])
  @@index([date])
}

model ExpenseSplit {
  id         String   @id @default(uuid())
  expenseId  String
  userId     String
  amount     Decimal  @db.Decimal(12, 2)
  percentage Decimal? @db.Decimal(5, 2)
  shares     Int?
  isPaid     Boolean  @default(false)
  paidAt     DateTime?

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@map("expense_splits")
  @@index([expenseId])
  @@index([userId])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  icon      String?
  color     String?
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())

  expenses Expense[]

  @@map("categories")
}

// ============================================================
// Settlements
// ============================================================

model Settlement {
  id          String           @id @default(uuid())
  groupId     String
  fromUserId  String
  toUserId    String
  amount      Decimal          @db.Decimal(12, 2)
  currency    String           @default("USD")
  status      SettlementStatus @default(PENDING)
  note        String?
  settledAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  group    Group @relation(fields: [groupId], references: [id])
  fromUser User  @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser   User  @relation("SettlementTo", fields: [toUserId], references: [id])

  @@map("settlements")
  @@index([groupId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
}

// ============================================================
// Notifications
// ============================================================

model Notification {
  id        String           @id @default(uuid())
  userId    String
  groupId   String?
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id])

  @@map("notifications")
  @@index([userId])
  @@index([userId, isRead])
}

// ============================================================
// Polls
// ============================================================

model Poll {
  id          String     @id @default(uuid())
  groupId     String
  question    String
  description String?
  status      PollStatus @default(ACTIVE)
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  group   Group        @relation(fields: [groupId], references: [id])
  options PollOption[]

  @@map("polls")
  @@index([groupId])
  @@index([status])
}

model PollOption {
  id     String @id @default(uuid())
  pollId String
  text   String
  order  Int    @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@map("poll_options")
  @@index([pollId])
}

model PollVote {
  id       String   @id @default(uuid())
  optionId String
  userId   String
  votedAt  DateTime @default(now())

  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id])

  @@unique([optionId, userId])
  @@map("poll_votes")
}

// ============================================================
// Itinerary
// ============================================================

model Itinerary {
  id          String          @id @default(uuid())
  groupId     String
  title       String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  destination String?
  status      ItineraryStatus @default(DRAFT)
  aiGenerated Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  group Group          @relation(fields: [groupId], references: [id])
  items ItineraryItem[]

  @@map("itineraries")
  @@index([groupId])
}

model ItineraryItem {
  id           String    @id @default(uuid())
  itineraryId  String
  title        String
  description  String?
  location     String?
  startTime    DateTime?
  endTime      DateTime?
  estimatedCost Decimal? @db.Decimal(12, 2)
  order        Int       @default(0)
  notes        String?

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@map("itinerary_items")
  @@index([itineraryId])
}

// ============================================================
// AI / Recommendations
// ============================================================

model Recommendation {
  id          String   @id @default(uuid())
  groupId     String
  type        String
  title       String
  content     Json
  metadata    Json?
  score       Float?
  isActedOn   Boolean  @default(false)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@map("recommendations")
  @@index([groupId])
  @@index([type])
}

model AiConversation {
  id        String   @id @default(uuid())
  userId    String
  groupId   String?
  messages  Json
  context   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_conversations")
  @@index([userId])
}

// ============================================================
// Audit
// ============================================================

model AuditLog {
  id          String      @id @default(uuid())
  userId      String?
  action      AuditAction
  entity      String
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  correlationId String?
  createdAt   DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}
